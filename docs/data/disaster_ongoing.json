        "wind_kt_max": 48,
        "wind_kt": 48,
        "pressure_mb": 989,
        "development_phrase": "REMAINS",
        "development_level": "LOW",
        "bulletin_issue_at": "2026-04-11T06:00:00+00:00"
      }
