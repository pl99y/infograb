        "lon": 171.2,
        "wind_kt_min": 28,
        "wind_kt_max": 33,
        "pressure_mb": 998,
        "development_phrase": "UPGRADED TO",
        "development_level": "HIGH",
        "bulletin_issue_at": "2026-04-04T11:30:00+00:00"
      }
